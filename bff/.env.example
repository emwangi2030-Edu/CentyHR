# Public ERP site URL (no trailing slash)
ERP_BASE_URL=https://erp.tarakilishicloud.com

# Optional: only if your proxy requires it
# ERP_SITE_NAME=erp.tarakilishicloud.com

PORT=3040

# When behind OpenLiteSpeed/nginx path routing (see README). Must match Pay Hub `HR_BFF_PATH_PREFIX` (default `/hr-api`).
# Leave unset only for local dev; then set Pay Hub `HR_BFF_PATH_PREFIX=` (empty) so `/api/hr/v1/*` proxies to `/v1/*`.
# BASE_PATH=/hr-api

# Optional: expense policy / workflow + employee self-onboarding invites (see supabase/migrations/ and ../REMOTE.md)
# SUPABASE_URL=https://ezepspwuahmtvhwcqhew.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service_role from Supabase Dashboard → Project Settings → API>

# --- Two-stage HR approvals (ERP custom Check fields; see docs/ERP_TWO_STAGE_CUSTOM_FIELDS.md) ---
# LEAVE_TWO_STAGE_APPROVAL=1
# EXPENSE_TWO_STAGE_APPROVAL=1
# LEAVE_FIRST_APPROVER_FIELD=custom_centy_first_approver_done
# EXPENSE_FIRST_APPROVER_FIELD=custom_centy_first_approver_done
# LEAVE_HR_BYPASS_FIRST_APPROVER=0
# EXPENSE_HR_BYPASS_FIRST_APPROVER=0
#
# Leave: line managers only above this many days need HR (single-stage / legacy mode)
# LEAVE_MANAGER_APPROVE_MAX_DAYS=

# Frappe API user (required for DocuSeal webhook forward and many routes)
# ERP_API_KEY=
# ERP_API_SECRET=
#
# Bridge mode (`HR_BRIDGE_SECRET` + `X-Bridge-Auth`): the BFF reads fallback keys from
# `HR_ERP_API_KEY` / `HR_ERP_API_SECRET` (see `src/config.ts`). If your `.env` only has
# `ERP_API_KEY` / `ERP_API_SECRET`, duplicate those values here or Pay Hub must send
# `X-Erp-Api-Key` / `X-Erp-Api-Secret` on every proxied request.
# HR_ERP_API_KEY=
# HR_ERP_API_SECRET=

# DocuSeal → POST {BASE_PATH}/v1/webhooks/docuseal (must match console “Add Secret”)
# DOCUSEAL_WEBHOOK_HEADER_NAME=X-Centy-Docuseal
# DOCUSEAL_WEBHOOK_SECRET=<same value as in DocuSeal>
# DOCUSEAL_WEBHOOK_ERP_METHOD=centypay_dms.api.documents.handle_docuseal_webhook
# DOCUSEAL_WEBHOOK_INSECURE=1

# Comma-separated app roles allowed to manage company vault docs (default: super_admin,admin)
# HR_COMPANY_DOCUMENT_ROLES=super_admin,admin

# --- Development only (never in production) ---
# DEV_INSECURE_HEADERS=1
