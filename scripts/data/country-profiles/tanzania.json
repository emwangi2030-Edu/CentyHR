{
  "country": "Tanzania",
  "currency": "TZS",
  "phone_prefix": "+255",
  "notes": [
    "PAYE bands and contribution rates are illustrative for the 2026 demo.",
    "HR/Finance must verify against the latest TRA, NSSF TZ, VETA (SDL) and WCF gazettes before any production payroll run.",
    "Income Tax Slab is annual (HRMS convention). Monthly bands multiplied by 12.",
    "Eid and Maulid dates are lunar; update yearly."
  ],
  "holiday_list": {
    "name_template": "Tanzania Public Holidays {year}",
    "from_date": "{year}-01-01",
    "to_date": "{year}-12-31",
    "country": "Tanzania",
    "holidays_fixed": [
      ["{year}-01-01", "New Year's Day"],
      ["{year}-01-12", "Zanzibar Revolution Day"],
      ["{year}-04-07", "Karume Day"],
      ["{year}-04-26", "Union Day"],
      ["{year}-05-01", "Workers' Day"],
      ["{year}-07-07", "Saba Saba"],
      ["{year}-08-08", "Nane Nane (Farmers') Day"],
      ["{year}-10-14", "Mwalimu Nyerere Day"],
      ["{year}-12-09", "Independence Day"],
      ["{year}-12-25", "Christmas Day"],
      ["{year}-12-26", "Boxing Day"]
    ],
    "holidays_by_year": {
      "2026": [
        ["2026-04-03", "Good Friday"],
        ["2026-04-06", "Easter Monday"],
        ["2026-03-20", "Eid al-Fitr (estimated)"],
        ["2026-05-27", "Eid al-Adha (estimated)"],
        ["2026-08-26", "Maulid (Prophet's Birthday, estimated)"]
      ]
    }
  },
  "salary_components": [
    {"name": "Basic Pay", "type": "Earning", "abbr": "BP", "reuse_existing": true, "description": "Reused (KE structures use the same component)."},
    {"name": "PAYE TZ", "type": "Deduction", "abbr": "PAYE_TZ", "variable_based_on_taxable_salary": 1, "is_tax_applicable": 1, "depends_on_payment_days": 0, "description": "Slab-driven; no formula. Bands defined on Income Tax Slab."},
    {"name": "NSSF TZ", "type": "Deduction", "abbr": "NSSF_TZ", "depends_on_payment_days": 0, "description": "Employee 10% of Basic; no upper cap in TZ."},
    {"name": "NSSF TZ Employer", "type": "Deduction", "abbr": "NSSF_TZ_E", "statistical_component": 1, "do_not_include_in_total": 1, "depends_on_payment_days": 0, "description": "Employer match 10%; statistical (does not reduce net)."},
    {"name": "SDL TZ", "type": "Deduction", "abbr": "SDL_TZ", "statistical_component": 1, "do_not_include_in_total": 1, "depends_on_payment_days": 0, "description": "Skills Development Levy 3.5%, employer-borne."},
    {"name": "WCF TZ", "type": "Deduction", "abbr": "WCF_TZ", "statistical_component": 1, "do_not_include_in_total": 1, "depends_on_payment_days": 0, "description": "Workers Compensation Fund 0.5%, employer-borne."}
  ],
  "income_tax_slab": {
    "name_template": "Tanzania PAYE {year} - {company}",
    "effective_from": "{year}-01-01",
    "allow_tax_exemption": 0,
    "standard_tax_exemption_amount": 0,
    "tax_relief_limit": 0,
    "_band_basis": "annual; monthly_basis x 12 (TZ PAYE 2025 monthly bands)",
    "slabs": [
      {"from_amount": 0,        "to_amount": 3240000,  "percent_deduction": 0},
      {"from_amount": 3240001,  "to_amount": 6240000,  "percent_deduction": 8},
      {"from_amount": 6240001,  "to_amount": 9120000,  "percent_deduction": 20},
      {"from_amount": 9120001,  "to_amount": 12000000, "percent_deduction": 25},
      {"from_amount": 12000001, "to_amount": 0,        "percent_deduction": 30}
    ]
  },
  "payroll_period": {
    "name_template": "{year} - {company}",
    "start_date": "{year}-01-01",
    "end_date": "{year}-12-31"
  },
  "salary_structure": {
    "name_template": "Tanzania Standard Payroll - {company}",
    "payroll_frequency": "Monthly",
    "_uses_income_tax_slab": true,
    "earnings": [
      {"salary_component": "Basic Pay", "amount_based_on_formula": 1, "formula": "base"}
    ],
    "deductions": [
      {"salary_component": "NSSF TZ",          "amount_based_on_formula": 1, "formula": "round(BP * 0.10, 2)"},
      {"salary_component": "NSSF TZ Employer", "amount_based_on_formula": 1, "formula": "round(BP * 0.10, 2)", "statistical_component": 1, "do_not_include_in_total": 1},
      {"salary_component": "SDL TZ",           "amount_based_on_formula": 1, "formula": "round(gross_pay * 0.035, 2)", "statistical_component": 1, "do_not_include_in_total": 1},
      {"salary_component": "WCF TZ",           "amount_based_on_formula": 1, "formula": "round(gross_pay * 0.005, 2)", "statistical_component": 1, "do_not_include_in_total": 1},
      {"salary_component": "PAYE TZ",          "amount_based_on_formula": 0}
    ]
  },
